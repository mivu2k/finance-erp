@page "/requests/{Id:int}"
@attribute [Authorize]
@inject IServiceScopeFactory ScopeFactory
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Request Detail</PageTitle>

@if (_request is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <div class="d-flex align-center mb-4 flex-wrap gap-2">
        <MudText Typo="Typo.h5">@_request.RequestNo</MudText>
        <StatusChip Status="@_request.Status" />
        @if (_request.IsDirectorRequest)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Info">Director Fund</MudChip>
        }
        @if (_request.Kind == RequestKind.Advance)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Tertiary">Advance</MudChip>
        }
        <MudSpacer />
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/requests/my"))">Back</MudButton>
        @if (_request.Status == RequestStatus.Draft)
        {
            <MudButton Variant="Variant.Outlined" Href="@($"/requests/{_request.Id}/edit")">Edit</MudButton>
        }
        @if (_request.Status is RequestStatus.Draft or RequestStatus.PendingManager && _isOwner)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="Cancel" Disabled="@_busy">Cancel Request</MudButton>
        }
    </div>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle2" Class="mb-1">
                    Requester: <b>@_request.RequesterName</b> · Department: @(_request.Department?.Name ?? "—") · Project: @(_request.Project?.Name ?? "—")
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-3">@_request.Purpose</MudText>
                @if (_request.Kind == RequestKind.Advance)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        Advance amount: <b>@_request.TotalAmount.ToString("N2")</b>
                        @if (_request.Lines.Count > 0)
                        {
                            var actual = _request.Lines.Sum(l => l.Amount);
                            var diff = _request.TotalAmount - actual;
                            <span> · Justified: <b>@actual.ToString("N2")</b> ·
                            @(diff > 0 ? $"To return: {diff:N2}" : diff < 0 ? $"To reimburse: {(-diff):N2}" : "Fully utilised")</span>
                        }
                    </MudAlert>
                }
                <MudSimpleTable Dense="true">
                    <thead>
                        <tr>
                            <th>Category</th><th>Reason</th>
                            <th>Account head</th>
                            <th style="text-align:right">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in _request.Lines)
                        {
                            <tr>
                                <td>@l.Category</td>
                                <td>
                                    @l.Reason @l.Description
                                    @if (l.AttachmentPath is not null)
                                    {
                                        <MudLink Href="@($"/files/receipts/{l.AttachmentPath}")" Target="_blank" Class="ml-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" title="@l.AttachmentName" />
                                        </MudLink>
                                    }
                                </td>
                                <td>
                                    @if (_canClassify)
                                    {
                                        <MudSelect T="int?" Value="@_lineAccounts.GetValueOrDefault(l.Id)"
                                                   ValueChanged="@(v => _lineAccounts[l.Id] = v)"
                                                   Dense="true" Margin="Margin.Dense" Placeholder="Assign account…">
                                            @foreach (var a in _postableAccounts)
                                            {
                                                <MudSelectItem T="int?" Value="@a.Id">@a.Code — @a.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        @(l.Account is null ? "—" : $"{l.Account.Code} {l.Account.Name}")
                                    }
                                </td>
                                <td style="text-align:right">@l.Amount.ToString("N2")</td>
                            </tr>
                        }
                        <tr style="font-weight:600">
                            <td colspan="3">Total</td>
                            <td style="text-align:right">@_request.TotalAmount.ToString("N2")</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
                @if (_request.Voucher is not null)
                {
                    <MudAlert Severity="Severity.Success" Class="mt-3">
                        @(_request.Kind == RequestKind.Advance ? "Disbursed" : "Paid") via voucher
                        <MudLink Href="@($"/vouchers/{_request.VoucherId}")">@_request.Voucher.VoucherNo</MudLink>
                    </MudAlert>
                }
                @if (_request.SettlementVoucher is not null)
                {
                    <MudAlert Severity="Severity.Success" Class="mt-2">
                        Settled via voucher <MudLink Href="@($"/vouchers/{_request.SettlementVoucherId}")">@_request.SettlementVoucher.VoucherNo</MudLink>
                    </MudAlert>
                }
            </MudPaper>

            @if (_request.Status == RequestStatus.PendingManager)
            {
                <AuthorizeView Policy="@Permissions.RequestsApproveManager">
                    <ApprovalPanel Level="Manager" Busy="@_busy" OnApprove="Approve" OnReject="Reject" />
                </AuthorizeView>
            }
            else if (_request.Status == RequestStatus.PendingAdmin)
            {
                <AuthorizeView Policy="@Permissions.RequestsApproveAdmin">
                    <ApprovalPanel Level="Admin" Busy="@_busy" OnApprove="Approve" OnReject="Reject" />
                </AuthorizeView>
            }
            else if (_request.Status == RequestStatus.PendingAccountant && _request.Kind == RequestKind.Advance)
            {
                <AuthorizeView Policy="@Permissions.RequestsPay">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-1">Disburse Advance</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            Hands @_request.TotalAmount.ToString("N2") to @_request.RequesterName and books it against their
                            advance account. Expenses are classified later, at settlement.
                        </MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="_payFromAccountId" Label="Pay from account">
                                    @foreach (var a in _cashAccounts)
                                    {
                                        <MudSelectItem T="int?" Value="@a.Id">@a.Code — @a.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_comment" Label="Comment (optional)" />
                            </MudItem>
                        </MudGrid>
                        <div class="d-flex gap-2 mt-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Disburse"
                                       Disabled="@(_busy || _payFromAccountId is null)">Disburse</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="@_busy"
                                       OnClick="@(() => Reject(("Accountant", _comment)))">Reject</MudButton>
                        </div>
                    </MudPaper>
                </AuthorizeView>
            }
            else if (_request.Status == RequestStatus.Disbursed && _isOwner)
            {
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-1">Submit Expense Justification</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                        Report what you actually spent, by category. It goes to admin for approval, then accounts settles it.
                    </MudText>
                    @foreach (var line in _justification)
                    {
                        <MudGrid Spacing="2" Class="mb-1">
                            <MudItem xs="12" sm="3">
                                <MudSelect T="string" @bind-Value="line.Category" Label="Category" Margin="Margin.Dense">
                                    @foreach (var c in _categories)
                                    {
                                        <MudSelectItem Value="@c">@c</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="6" sm="2">
                                <MudNumericField T="decimal" @bind-Value="line.Amount" Label="Amount" Min="0" Format="N2" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="6" sm="4">
                                <MudTextField @bind-Value="line.Reason" Label="Reason" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="8" sm="2" Class="d-flex align-center">
                                <ReceiptUpload Line="@line" />
                            </MudItem>
                            <MudItem xs="4" sm="1" Class="d-flex align-center">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               Disabled="@(_justification.Count == 1)"
                                               OnClick="@(() => _justification.Remove(line))" />
                            </MudItem>
                        </MudGrid>
                    }
                    <div class="d-flex align-center gap-2 mt-2 flex-wrap">
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined"
                                   OnClick="@(() => _justification.Add(new PaymentRequestLine()))">Add expense</MudButton>
                        <MudSpacer />
                        <MudText Typo="Typo.subtitle1">
                            Spent: @_justification.Sum(l => l.Amount).ToString("N2") of @_request.TotalAmount.ToString("N2")
                        </MudText>
                    </div>
                    <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitJustification"
                               Disabled="@(_busy || !_justification.Any(l => l.Amount > 0))">
                        Submit Justification
                    </MudButton>
                </MudPaper>
            }
            else if (_request.Status == RequestStatus.JustificationPending)
            {
                <AuthorizeView Policy="@Permissions.RequestsApproveAdmin">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Justification Review</MudText>
                        @{ var overspend = _request.Lines.Sum(l => l.Amount) - _request.TotalAmount; }
                        @if (overspend > 0)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-3">
                                <b>Overspend:</b> @_request.RequesterName spent @overspend.ToString("N2") more than the
                                advance of @_request.TotalAmount.ToString("N2"). Approving authorizes reimbursing this
                                extra amount at settlement.
                            </MudAlert>
                        }
                        <MudTextField @bind-Value="_comment" Label="Comment (optional)" Class="mb-3" />
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@_busy"
                                       OnClick="ApproveJustification">Approve Justification</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="@_busy"
                                       OnClick="ReturnJustification">Return for Rework</MudButton>
                        </div>
                    </MudPaper>
                </AuthorizeView>
            }
            else if (_request.Status == RequestStatus.SettlementReady)
            {
                <AuthorizeView Policy="@Permissions.RequestsPay">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-1">Settle Advance</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            Assign account heads above, then settle: actuals post to expenses, the advance account is
                            cleared, and any difference moves through the cash account below.
                        </MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="_payFromAccountId" Label="Cash account for difference">
                                    @foreach (var a in _cashAccounts)
                                    {
                                        <MudSelectItem T="int?" Value="@a.Id">@a.Code — @a.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_comment" Label="Comment (optional)" />
                            </MudItem>
                        </MudGrid>
                        <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Success" OnClick="Settle"
                                   Disabled="@(_busy || _payFromAccountId is null || !AllLinesClassified)">
                            Post Settlement
                        </MudButton>
                        @if (!AllLinesClassified)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-2 d-block">
                                Assign an account head to every line to enable settlement.
                            </MudText>
                        }
                    </MudPaper>
                </AuthorizeView>
            }
            else if (_request.Status == RequestStatus.PendingAccountant)
            {
                <AuthorizeView Policy="@Permissions.RequestsPay">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-1">Classify &amp; Pay</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            Assign an account head to each line above, choose the paying account, then create the voucher.
                        </MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudSelect T="int?" @bind-Value="_payFromAccountId" Label="Pay from account">
                                    @foreach (var a in _cashAccounts)
                                    {
                                        <MudSelectItem T="int?" Value="@a.Id">@a.Code — @a.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_comment" Label="Comment (optional)" />
                            </MudItem>
                        </MudGrid>
                        <div class="d-flex gap-2 mt-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Pay"
                                       Disabled="@(_busy || _payFromAccountId is null || !AllLinesClassified)">
                                @if (_busy)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                Create Voucher &amp; Pay
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="@_busy"
                                       OnClick="@(() => Reject(("Accountant", _comment)))">Reject</MudButton>
                        </div>
                        @if (!AllLinesClassified)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-2">
                                Assign an account head to every line to enable payment.
                            </MudText>
                        }
                    </MudPaper>
                </AuthorizeView>
            }
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Approval Trail</MudText>
                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    @foreach (var a in _request.Approvals.OrderBy(x => x.Id))
                    {
                        <MudTimelineItem Color="@(a.Action == ApprovalAction.Rejected ? Color.Error : Color.Success)" Size="Size.Small">
                            <MudText Typo="Typo.body2"><b>@a.Level</b> — @a.Action</MudText>
                            <MudText Typo="Typo.caption">@a.ActorName · @a.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                            @if (!string.IsNullOrEmpty(a.Comment))
                            {
                                <MudText Typo="Typo.caption">"@a.Comment"</MudText>
                            }
                        </MudTimelineItem>
                    }
                </MudTimeline>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public int Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private PaymentRequest? _request;
    private List<Account> _cashAccounts = [];
    private List<Account> _postableAccounts = [];
    private List<string> _categories = [];
    private List<PaymentRequestLine> _justification = [new()];
    private readonly Dictionary<int, int?> _lineAccounts = [];
    private int? _payFromAccountId;
    private string? _comment;
    private bool _busy;
    private bool _isOwner;
    private bool _canClassify;

    private bool AllLinesClassified =>
        _request is not null && _request.Lines.All(l => _lineAccounts.GetValueOrDefault(l.Id) is not null);

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        _request = await scope.ServiceProvider.GetRequiredService<IPaymentRequestService>().GetAsync(Id);
        var db = scope.ServiceProvider.GetRequiredService<FinanceERP.Infrastructure.Persistence.AppDbContext>();
        _cashAccounts = db.Accounts.Where(a => a.Code == "1100" || a.Code == "1201" || a.Code == "1300").ToList();
        _payFromAccountId ??= _cashAccounts.FirstOrDefault()?.Id;
        _postableAccounts = db.Accounts.Where(a => a.IsPostable && a.IsActive
                && (a.Type == AccountType.Expense || a.Type == AccountType.Asset))
            .OrderBy(a => a.Code).ToList();
        _categories = _postableAccounts.Where(a => a.Type == AccountType.Expense)
            .Select(a => a.Name).OrderBy(n => n).ToList();

        if (AuthState is not null && _request is not null)
        {
            var auth = await AuthState;
            _isOwner = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == _request.RequesterId;
            _canClassify = (_request.Status == RequestStatus.PendingAccountant && _request.Kind == RequestKind.Reimbursement
                    || _request.Status == RequestStatus.SettlementReady)
                && auth.User.HasClaim(Permissions.ClaimType, Permissions.RequestsPay);
        }

        // Pre-fill classification: match category text to an account name.
        if (_request is not null && _canClassify)
            foreach (var l in _request.Lines)
                if (!_lineAccounts.ContainsKey(l.Id))
                    _lineAccounts[l.Id] = l.AccountId
                        ?? _postableAccounts.FirstOrDefault(a => a.Name == l.Category)?.Id;

        StateHasChanged();
    }

    private Task Approve((string Level, string? Comment) args) => Run(async svc =>
    {
        await svc.ApproveAsync(Id, args.Level, args.Comment);
        Snackbar.Add($"Approved at {args.Level} level.", Severity.Success);
    });

    private Task Reject((string Level, string? Comment) args) => Run(async svc =>
    {
        await svc.RejectAsync(Id, args.Level, args.Comment);
        Snackbar.Add("Request rejected.", Severity.Warning);
    });

    private Task Cancel() => Run(async svc =>
    {
        await svc.CancelAsync(Id);
        Snackbar.Add("Request cancelled.", Severity.Info);
    });

    private Task Disburse() => Run(async svc =>
    {
        var voucher = await svc.DisburseAsync(Id, _payFromAccountId!.Value, _comment);
        Snackbar.Add($"Disbursed — voucher {voucher.VoucherNo} posted.", Severity.Success);
    });

    private Task SubmitJustification() => Run(async svc =>
    {
        await svc.SubmitJustificationAsync(Id, _justification);
        Snackbar.Add("Justification submitted for admin approval.", Severity.Success);
        _justification = [new PaymentRequestLine()];
    });

    private Task ApproveJustification() => Run(async svc =>
    {
        await svc.ApproveJustificationAsync(Id, _comment);
        Snackbar.Add("Justification approved — ready for settlement.", Severity.Success);
    });

    private Task ReturnJustification() => Run(async svc =>
    {
        await svc.RejectJustificationAsync(Id, _comment);
        Snackbar.Add("Justification returned for rework.", Severity.Warning);
    });

    private Task Settle() => Run(async svc =>
    {
        var mapping = _lineAccounts
            .Where(kv => kv.Value is not null)
            .ToDictionary(kv => kv.Key, kv => kv.Value!.Value);
        var voucher = await svc.SettleAsync(Id, _payFromAccountId!.Value, _comment, mapping);
        Snackbar.Add($"Settled — voucher {voucher.VoucherNo} posted.", Severity.Success);
    });

    private Task Pay() => Run(async svc =>
    {
        var mapping = _lineAccounts
            .Where(kv => kv.Value is not null)
            .ToDictionary(kv => kv.Key, kv => kv.Value!.Value);
        var voucher = await svc.PayAsync(Id, _payFromAccountId!.Value, _comment, mapping);
        Snackbar.Add($"Paid — voucher {voucher.VoucherNo} posted.", Severity.Success);
    });

    private async Task Run(Func<IPaymentRequestService, Task> action)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            await action(scope.ServiceProvider.GetRequiredService<IPaymentRequestService>());
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }
}
