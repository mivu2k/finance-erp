@page "/requests/new"
@page "/requests/{Id:int}/edit"
@attribute [Authorize(Policy = Permissions.RequestsCreate)]
@inject IServiceScopeFactory ScopeFactory
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Money Request</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">@(_model.Id == 0 ? (_isDirector ? "New Director Fund Request" : "New Money Request") : $"Edit {_model.RequestNo}")</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Describe what you need money for. After approval, the accounts team classifies and pays it — you don't need to know any account codes.
</MudText>

@if (_model.Id == 0)
{
    <MudPaper Class="pa-4 mb-4">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Request type</MudText>
        <MudRadioGroup T="RequestKind" @bind-Value="_model.Kind">
            <MudRadio T="RequestKind" Value="RequestKind.Advance" Color="Color.Primary">
                <b>Advance</b> — I need a lump sum now (e.g. a trip); I'll justify the expenses by category when I'm back.
            </MudRadio>
            <MudRadio T="RequestKind" Value="RequestKind.Reimbursement" Color="Color.Primary">
                <b>Itemized</b> — I already know the exact items and amounts.
            </MudRadio>
        </MudRadioGroup>
    </MudPaper>
}

<MudPaper Class="pa-4 mb-4">
    <MudGrid Spacing="2">
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_model.Purpose" Label="Purpose" Required="true"
                          HelperText="One line summary, e.g. 'Site visit expenses for Lahore trip'" />
        </MudItem>
        <MudItem xs="6" md="3">
            <MudSelect T="int?" @bind-Value="_model.DepartmentId" Label="Department" Clearable="true">
                @foreach (var d in _departments)
                {
                    <MudSelectItem T="int?" Value="@d.Id">@d.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudSelect T="int?" @bind-Value="_model.ProjectId" Label="Project" Clearable="true">
                @foreach (var p in _projects)
                {
                    <MudSelectItem T="int?" Value="@p.Id">@p.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-4">
    @if (_model.Kind == RequestKind.Advance)
    {
        <MudText Typo="Typo.subtitle1" Class="mb-3">How much do you need?</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4">
                <MudNumericField T="decimal" @bind-Value="_model.TotalAmount" Label="Advance amount" Min="0" Format="N2" />
            </MudItem>
        </MudGrid>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            After the money is disbursed and spent, open this request again to submit your expense justification.
        </MudText>
    }
    else
    {
    <MudText Typo="Typo.subtitle1" Class="mb-3">What do you need?</MudText>

    @foreach (var line in _model.Lines)
    {
        <MudPaper Outlined="true" Class="pa-3 mb-3">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4" md="3">
                    <MudSelect T="string" @bind-Value="line.Category" Label="Category *" Margin="Margin.Dense">
                        @foreach (var c in _categories)
                        {
                            <MudSelectItem Value="@c">@c</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3" md="2">
                    <MudNumericField T="decimal" @bind-Value="line.Amount" Label="Amount *" Min="0" Format="N2" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="5" md="3">
                    <MudTextField @bind-Value="line.Reason" Label="Reason *" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="10" sm="10" md="3">
                    <MudTextField @bind-Value="line.Description" Label="Details (optional)" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2" sm="2" md="1" Class="d-flex align-center justify-end">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   Disabled="@(_model.Lines.Count == 1)"
                                   OnClick="@(() => _model.Lines.Remove(line))" />
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    <div class="d-flex align-center flex-wrap gap-2 mt-2">
        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined"
                   OnClick="@(() => _model.Lines.Add(new PaymentRequestLine()))">Add another item</MudButton>
        <MudSpacer />
        <MudText Typo="Typo.h6" Class="mr-4">Total: @_model.Lines.Sum(l => l.Amount).ToString("N2")</MudText>
    </div>
    }

    <MudDivider Class="my-4" />

    <div class="d-flex gap-2 flex-wrap">
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="@_busy">Cancel</MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => Save(false))" Disabled="@_busy">
            Save Draft
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Save(true))"
                   Disabled="@(_busy || !IsValid)">
            @if (_busy)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Submit for Approval
        </MudButton>
    </div>
</MudPaper>

@code {
    [Parameter] public int? Id { get; set; }
    [SupplyParameterFromQuery(Name = "director")] public bool _isDirector { get; set; }

    private PaymentRequest _model = new();
    private List<Department> _departments = [];
    private List<Project> _projects = [];
    private List<string> _categories = [];
    private bool _busy;

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_model.Purpose)
        && (_model.Kind == RequestKind.Advance
            ? _model.TotalAmount > 0
            : _model.Lines.Any()
              && _model.Lines.All(l => l.Amount > 0 && !string.IsNullOrWhiteSpace(l.Category) && !string.IsNullOrWhiteSpace(l.Reason)));

    protected override async Task OnInitializedAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<FinanceERP.Infrastructure.Persistence.AppDbContext>();
        _departments = db.Departments.Where(d => d.IsActive).OrderBy(d => d.Name).ToList();
        _projects = db.Projects.Where(p => p.IsActive).OrderBy(p => p.Name).ToList();
        // Categories come from expense account names, so accountants can map them 1:1 later.
        _categories = db.Accounts
            .Where(a => a.Type == AccountType.Expense && a.IsPostable && a.IsActive)
            .OrderBy(a => a.Name).Select(a => a.Name).ToList();

        if (Id is not null)
        {
            var existing = await scope.ServiceProvider.GetRequiredService<IPaymentRequestService>().GetAsync(Id.Value);
            if (existing is null || existing.Status != RequestStatus.Draft) { Nav.NavigateTo("/requests/my"); return; }
            _model = existing;
            if (_model.Lines.Count == 0) _model.Lines.Add(new PaymentRequestLine());
        }
        else
        {
            _model.IsDirectorRequest = _isDirector;
            _model.Lines.Add(new PaymentRequestLine());
        }
    }

    private void Cancel() => Nav.NavigateTo(_model.IsDirectorRequest ? "/director-funds" : "/requests/my");

    private async Task Save(bool submit)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            if (_model.Kind == RequestKind.Advance)
            {
                _model.Lines = [];
                if (_model.TotalAmount <= 0) throw new InvalidOperationException("Enter the advance amount.");
            }
            else
            {
                _model.Lines = _model.Lines.Where(l => l.Amount > 0 || !string.IsNullOrWhiteSpace(l.Category)).ToList();
                if (_model.Lines.Count == 0) throw new InvalidOperationException("Add at least one item.");
            }
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<IPaymentRequestService>();
            var saved = await svc.SaveDraftAsync(_model);
            if (submit) await svc.SubmitAsync(saved.Id);
            Snackbar.Add(submit ? $"{saved.RequestNo} submitted for approval." : $"{saved.RequestNo} saved as draft.", Severity.Success);
            Cancel();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _busy = false;
        }
    }
}
