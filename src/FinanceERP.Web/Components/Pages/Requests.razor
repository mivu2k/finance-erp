@page "/requests"
@page "/requests/my"
@page "/approvals"
@page "/director-funds"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Nav

<PageTitle>@Title</PageTitle>

<div class="d-flex align-center mb-4 flex-wrap gap-2">
    <MudText Typo="Typo.h5">@Title</MudText>
    <MudSpacer />
    @if (Mode is "my" or "director")
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Href="@(Mode == "director" ? "/requests/new?director=true" : "/requests/new")">New Request</MudButton>
    }
</div>

<MudPaper Class="pa-4 mb-4">
    <MudGrid Spacing="2">
        <MudItem xs="8" md="4"><MudTextField @bind-Value="_search" Label="Search" Immediate="true" /></MudItem>
        <MudItem xs="4" md="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => _table!.ReloadServerData())">Search</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable @ref="_table" T="PaymentRequest" ServerData="LoadData" Dense="true" Hover="true" Striped="true"
          OnRowClick="@(args => Nav.NavigateTo($"/requests/{args.Item!.Id}"))" RowStyle="cursor:pointer">
    <HeaderContent>
        <MudTh>Request No</MudTh><MudTh>Requester</MudTh><MudTh>Purpose</MudTh>
        <MudTh Style="text-align:right">Amount</MudTh><MudTh>Status</MudTh><MudTh>Created</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.RequestNo</MudTd>
        <MudTd>@context.RequesterName</MudTd>
        <MudTd>@context.Purpose</MudTd>
        <MudTd Style="text-align:right">@context.TotalAmount.ToString("N2")</MudTd>
        <MudTd><StatusChip Status="@context.Status" /></MudTd>
        <MudTd>@context.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
</MudTable>

@if (Mode == "approvals" && _pendingAdvances.Count > 0)
{
    <MudPaper Class="pa-2 mt-4">
        <MudText Typo="Typo.subtitle1" Class="pa-2">Employee Advances awaiting you</MudText>
        <MudSimpleTable Dense="true" Hover="true" Striped="true">
            <thead>
                <tr><th>No</th><th>Employee</th><th style="text-align:right">Amount</th><th>Reason</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var a in _pendingAdvances)
                {
                    <tr style="cursor:pointer" @onclick="@(() => Nav.NavigateTo($"/advances/{a.Id}"))">
                        <td>@a.AdvanceNo</td>
                        <td>@a.EmployeeName</td>
                        <td style="text-align:right">@a.Amount.ToString("N2")</td>
                        <td>@a.Reason</td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                @(a.Status == AdvanceStatus.PendingApproval ? "Pending Approval" : "Approved — Disburse")
                            </MudChip>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private MudTable<PaymentRequest>? _table;
    private string _search = "";
    private string? _userId;
    private readonly List<RequestStatus> _actionableStages = [];
    private List<EmployeeAdvance> _pendingAdvances = [];

    private string Mode => Nav.Uri.Contains("/approvals") ? "approvals"
        : Nav.Uri.Contains("/requests/my") ? "my"
        : Nav.Uri.Contains("/director-funds") ? "director"
        : "all";

    private string Title => Mode switch
    {
        "approvals" => "Pending Approvals",
        "my" => "My Requests",
        "director" => "Director Fund Requests",
        _ => "Payment Requests"
    };

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var auth = await AuthState;
            _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            // The approvals queue shows every stage the current user can act on.
            if (auth.User.HasClaim(Permissions.ClaimType, Permissions.RequestsApproveManager))
                _actionableStages.Add(RequestStatus.PendingManager);
            if (auth.User.HasClaim(Permissions.ClaimType, Permissions.RequestsApproveAdmin))
            {
                _actionableStages.Add(RequestStatus.PendingAdmin);
                _actionableStages.Add(RequestStatus.JustificationPending);
            }
            if (auth.User.HasClaim(Permissions.ClaimType, Permissions.RequestsPay))
            {
                _actionableStages.Add(RequestStatus.PendingAccountant);
                _actionableStages.Add(RequestStatus.SettlementReady);
            }

            if (Mode == "approvals")
            {
                var canApprove = auth.User.HasClaim(Permissions.ClaimType, Permissions.AdvancesApprove);
                var canDisburse = auth.User.HasClaim(Permissions.ClaimType, Permissions.AdvancesManage);
                if (canApprove || canDisburse)
                {
                    using var scope = ScopeFactory.CreateScope();
                    var db = scope.ServiceProvider.GetRequiredService<FinanceERP.Infrastructure.Persistence.AppDbContext>();
                    _pendingAdvances = await db.EmployeeAdvances.AsNoTracking()
                        .Where(a => (canApprove && a.Status == AdvanceStatus.PendingApproval)
                                 || (canDisburse && a.Status == AdvanceStatus.Approved))
                        .OrderBy(a => a.Id).Take(100).ToListAsync();
                }
            }
        }
    }

    private async Task<TableData<PaymentRequest>> LoadData(TableState state, CancellationToken ct)
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IPaymentRequestService>();
        var filter = new ReportFilter { Search = _search, Page = state.Page + 1, PageSize = state.PageSize };

        PagedResult<PaymentRequest> result = Mode switch
        {
            "my" => await svc.ListAsync(filter, _userId),
            _ => await svc.ListAsync(filter)
        };
        var items = Mode switch
        {
            "director" => result.Items.Where(r => r.IsDirectorRequest).ToList(),
            "approvals" => result.Items.Where(r => _actionableStages.Contains(r.Status)).ToList(),
            _ => result.Items.ToList()
        };
        return new TableData<PaymentRequest> { Items = items, TotalItems = result.TotalCount };
    }
}
