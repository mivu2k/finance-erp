<MudChip T="string" Size="Size.Small" Color="@ChipColor" Variant="Variant.Filled">@Label</MudChip>

@code {
    [Parameter] public RequestStatus Status { get; set; }

    private string Label => Status switch
    {
        RequestStatus.PendingManager => "Pending Manager",
        RequestStatus.PendingAdmin => "Pending Admin",
        RequestStatus.PendingAccountant => "Pending Accountant",
        RequestStatus.Disbursed => "Disbursed — Awaiting Justification",
        RequestStatus.JustificationPending => "Justification Pending",
        RequestStatus.SettlementReady => "Ready to Settle",
        _ => Status.ToString()
    };

    private Color ChipColor => Status switch
    {
        RequestStatus.Draft => Color.Default,
        RequestStatus.Paid or RequestStatus.Settled => Color.Success,
        RequestStatus.Rejected => Color.Error,
        RequestStatus.Cancelled => Color.Dark,
        RequestStatus.Disbursed => Color.Info,
        _ => Color.Warning
    };
}
