<MudItem xs="6" sm="4" md="3">
    <MudPaper Class="pa-4 d-flex align-center gap-3" Style="height:100%">
        <MudIcon Icon="@Icon" Color="@Color" Size="Size.Large" />
        <div>
            <MudText Typo="Typo.caption">@Title</MudText>
            <MudText Typo="Typo.h6">@Value.ToString("N2")</MudText>
        </div>
    </MudPaper>
</MudItem>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public decimal Value { get; set; }
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Numbers;
    [Parameter] public Color Color { get; set; } = Color.Primary;
}
